{
  "name": "linguashop",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "install-all": "cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1"
  },
  "vercel": {
    "builds": [
      {
        "src": "api/**/*.js",
        "use": "@vercel/node"
      },
      {
        "src": "frontend/dist/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/$1.js"
      },
      {
        "src": "/(.*)",
        "dest": "/frontend/dist/$1"
      }
    ]
  }
}
