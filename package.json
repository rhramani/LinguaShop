{
  "name": "linguashop",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm run build"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "vercel": {
    "builds": [
      {
        "src": "api/**/*.js",
        "use": "@vercel/node"
      },
      {
        "src": "frontend/dist/**",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/$1.js"
      },
      {
        "src": "/(.*)",
        "dest": "/frontend/dist/$1"
      }
    ]
  }
}
