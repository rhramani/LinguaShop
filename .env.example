# Shopify App Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=write_script_tags,read_products,write_products,write_translations,read_translations,read_locales,write_locales

# App URL (your Vercel deployment URL)
APP_URL=https://your-app.vercel.app

# Lingva Translate URL (free)
LINGVA_URL=https://lingva.ml/api/v1

# MongoDB (for production - optional)
MONGODB_URI=mongodb://localhost:27017/linguashop

# JWT Secret
JWT_SECRET=your_random_secret_key

# Demo Mode (set to false for production)
DEMO_MODE=true
