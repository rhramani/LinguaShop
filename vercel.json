{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth/index.js"
    },
    {
      "src": "/api/translate",
      "dest": "/api/translate/index.js"
    },
    {
      "src": "/api/settings/(.*)",
      "dest": "/api/settings/index.js"
    },
    {
      "src": "/api/usage/(.*)",
      "dest": "/api/usage/index.js"
    },
    {
      "src": "/api/widget/(.*)",
      "dest": "/api/widget/index.js"
    },
    {
      "src": "/api/billing/(.*)",
      "dest": "/api/billing/index.js"
    },
    {
      "src": "/api/webhooks/(.*)",
      "dest": "/api/webhooks/index.js"
    },
    {
      "src": "/auth",
      "dest": "/api/auth/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ]
}
